### Register a new user
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "name": "John Doe",
  "username": "john@example.com",
  "password": "password123",
  "masterKeyHash": "client-derived-auth-key-base64"
}

### Login
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "username": "john@example.com",
  "password": "password123",
  "masterKeyHash": "client-derived-auth-key-base64"
}

### Create a key
POST http://localhost:8080/keys
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "My SSH Key",
  "value": "encrypted-key-blob-base64",
  "passphrase": "encrypted-passphrase-blob-base64",
  "iv": "random-iv-base64"
}

### List keys
GET http://localhost:8080/keys
Authorization: Bearer <token>

### Get a key
GET http://localhost:8080/keys/1
Authorization: Bearer <token>

### Update a key
PUT http://localhost:8080/keys/1
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "Renamed SSH Key"
}

### Delete a key
DELETE http://localhost:8080/keys/1
Authorization: Bearer <token>

### Create a host (with password)
POST http://localhost:8080/hosts
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "My Server",
  "hostname": "192.168.1.100",
  "username": "root",
  "port": 22,
  "password": "encrypted-password-blob-base64",
  "iv": "random-iv-base64"
}

### Create a host (with key)
POST http://localhost:8080/hosts
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "My Server with Key",
  "hostname": "192.168.1.101",
  "username": "deploy",
  "keyId": 1,
  "iv": "random-iv-base64"
}

### Create a host (with both password and key)
POST http://localhost:8080/hosts
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "My Server Both",
  "hostname": "192.168.1.102",
  "username": "admin",
  "port": 2222,
  "password": "encrypted-password-blob-base64",
  "keyId": 1,
  "iv": "random-iv-base64"
}

### List hosts
GET http://localhost:8080/hosts
Authorization: Bearer <token>

### Get a host
GET http://localhost:8080/hosts/1
Authorization: Bearer <token>

### Update a host
PUT http://localhost:8080/hosts/1
Content-Type: application/json
Authorization: Bearer <token>

{
  "label": "Renamed Server",
  "port": 2222
}

### Delete a host
DELETE http://localhost:8080/hosts/1
Authorization: Bearer <token>

### Setup recovery (store encrypted master key)
POST http://localhost:8080/auth/recovery/setup
Content-Type: application/json
Authorization: Bearer <token>

{
  "encryptedMasterKey": "client-encrypted-master-key-blob-base64"
}

### Recover encrypted master key
POST http://localhost:8080/auth/recover
Content-Type: application/json

{
  "username": "john@example.com",
  "password": "password123",
  "recoveryKey": "recovery-key-from-registration"
}
